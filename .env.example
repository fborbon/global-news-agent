# AWS credentials for Amazon Bedrock (Nova models)
# Option A — IAM instance role (recommended for EC2, no keys needed)
# Option B — IAM user access keys (paste below)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Bedrock region — us-east-1 has full Nova model availability
BEDROCK_REGION=us-east-1

# When running the agent ON the EC2 server, set this to copy output locally
# instead of rsyncing over SSH. Leave blank when running from your laptop.
# DEPLOY_LOCAL_DIR=/var/www/forwardforecasting/newssummary
